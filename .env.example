# Copy this file to .env (for local development with a tool like
# `python-dotenv`/`honcho`, or `docker run --env-file .env`) and fill in
# real values. .env itself is gitignored - never commit real keys.
#
# See deployment_guide.md for where each of these gets set when deploying
# the backend to Railway and the frontend to Hugging Face Spaces.

# --- Backend (app_api.py / main.py) ---

# Which LLM provider powers every agent: "anthropic" (default, paid, no
# ongoing free tier) or "gemini" (has a real free tier via Google AI
# Studio - use this to test the project for free before paying for Claude).
# See the "Switching LLM providers" section of README.md.
LLM_PROVIDER=anthropic

# Required for the orkg, compare, and thesis commands/endpoints if
# LLM_PROVIDER=anthropic (the default). From https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Required instead of ANTHROPIC_API_KEY if LLM_PROVIDER=gemini.
# From https://aistudio.google.com - free tier, no payment required.
GEMINI_API_KEY=

# Required for the thesis command/endpoint's market research + TAM steps.
# Only one of these two is required, matching SEARCH_PROVIDER below.
TAVILY_API_KEY=
BRAVE_API_KEY=

# Which search backend the Venture Catalyst uses: "tavily" (default) or "brave".
SEARCH_PROVIDER=tavily

# Overrides the default model id for the configured LLM_PROVIDER. Leave
# unset to use the default (see src/agents/llm_client.py).
VENTUREGRAPH_MODEL=

# Comma-separated list of origins allowed to call this API (CORS). Set this
# to your deployed Streamlit frontend's exact URL in production instead of
# leaving the default "*" wide open.
CORS_ALLOW_ORIGINS=*

# --- Frontend (app_gui.py) ---

# Base URL of the deployed VentureGraph API backend (e.g. your Railway
# service's URL). Defaults to http://localhost:8000 for local development.
VENTUREGRAPH_API_URL=http://localhost:8000
